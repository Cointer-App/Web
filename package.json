  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@react-router/node": "8.2.0",
    "@react-router/serve": "8.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.36",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.2.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@react-router/dev": "8.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
